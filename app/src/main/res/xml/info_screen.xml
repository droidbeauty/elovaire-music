<?xml version="1.0" encoding="utf-8"?>
<about-screen>
    <!--
      ENTRY
      - title: visible title shown in the About screen.
      - description: visible supporting copy shown under the title.
      - logoUrl: optional image link for the first header row.
        Use @drawable/your_logo for bundled app artwork, or a content://,
        file://, or android.resource:// image link.

      LINK
      - label: visible button text.
      - url: destination opened when the pill is tapped.
      Icon is chosen automatically from the domain:
      instagram -> Instagram icon
      x.com / twitter.com -> X icon
      ko-fi.com / kofi.com -> Ko-fi icon
      anything else -> globe icon
    -->
    <entry
        title="Droid Beauty"
        description="Beautifully designed widgets and themes for Android to make your homescreen stunning. I'm also the creator of this music player app you're using right now"
        >
        <link
            label="Instagram"
            url="https://instagram.com/droidbeauty" />
        <link
            label="Twitter"
            url="https://x.com/droidbeauty" />
        <link
            label="Play Store"
            url="https://play.google.com/store/apps/dev?id=7791472155222642322" />
        <link
            label="Ko-fi"
            url="https://ko-fi.com/droidbeauty" />
    </entry>

    <entry
        title="Resources"
        description="Elovaire uses Apache-2.0 Android and Kotlin components, Lucide icons (ISC/MIT), Geist fonts (OFL-1.1), and jaudiotagger (LGPL). Full license texts are bundled with the app.">
        <link
            label="Android Developer"
            url="https://developer.android.com" />
        <link
            label="Lucide icons"
            url="https://lucide.dev/" />
        <link
            label="Geist font"
            url="https://github.com/vercel/geist-font" />
        <link
            label="jaudiotagger"
            url="https://bitbucket.org/ijabz/jaudiotagger" />
    </entry>
</about-screen>
